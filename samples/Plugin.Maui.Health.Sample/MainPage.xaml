<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Plugin.Maui.Health.Sample.ViewModels"
             xmlns:charts="clr-namespace:Plugin.Maui.Health.Sample.Controls"
             x:Class="Plugin.Maui.Health.Sample.MainPage"
             x:DataType="vm:MainPageViewModel"
             BackgroundColor="{StaticResource PageBackground}"
             Title="Plugin.Maui.Health Sample">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- Header -->
            <VerticalStackLayout Spacing="2">
                <Label Text="Your health" Style="{StaticResource ScreenTitle}" />
                <Label Text="Powered by Plugin.Maui.Health" Style="{StaticResource MutedLabel}" />
            </VerticalStackLayout>

            <!-- Today: goal ring + steps + exercise, with the weekly steps chart -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Today" Style="{StaticResource SectionHeader}" />
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="18">
                        <charts:RingChartView Grid.Column="0"
                                              WidthRequest="104" HeightRequest="104"
                                              Progress="{Binding StepsGoalProgress}"
                                              ValueText="{Binding StepsGoalText}"
                                              Caption="Goal"
                                              RingColor="{StaticResource AccentGreen}" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Steps today" Style="{StaticResource MetricCaption}" />
                            <Label Text="{Binding StepsTodayText}" Style="{StaticResource MetricValue}" />
                            <Label Text="Goal 10,000" Style="{StaticResource MutedLabel}" />
                            <Label Text="{Binding ExerciseText}" Style="{StaticResource MutedLabel}" Margin="0,6,0,0" />
                        </VerticalStackLayout>
                    </Grid>
                    <Label Text="This week" Style="{StaticResource MetricCaption}" />
                    <charts:BarChartView Entries="{Binding StepsThisWeek}" BarColor="{StaticResource AccentCyan}" />
                </VerticalStackLayout>
            </Border>

            <!-- At a glance: live tiles that tap through to their detail screen -->
            <Label Text="At a glance" Style="{StaticResource SectionHeader}" />
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="12">

                <!-- Heart rate -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenCommand}" CommandParameter="HeartRateView" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Heart rate" Style="{StaticResource MetricCaption}" />
                        <Label Text="{Binding HeartRateText}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource AccentPink}" />
                        <charts:LineChartView Entries="{Binding HeartRateTrend}" LineColor="{StaticResource AccentPink}" ShowDots="False" Compact="True" HeightRequest="44" />
                    </VerticalStackLayout>
                </Border>

                <!-- Sleep -->
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenCommand}" CommandParameter="SleepView" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Sleep" Style="{StaticResource MetricCaption}" />
                        <Label Text="{Binding SleepText}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource AccentViolet}" />
                        <charts:SleepStagesView Stages="{Binding SleepStages}" HeightRequest="44" />
                    </VerticalStackLayout>
                </Border>

                <!-- Weight -->
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenCommand}" CommandParameter="BodyMeasurementsView" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Weight" Style="{StaticResource MetricCaption}" />
                        <Label Text="{Binding WeightText}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource AccentBlue}" />
                        <charts:LineChartView Entries="{Binding WeightTrend}" LineColor="{StaticResource AccentBlue}" ShowDots="False" Compact="True" HeightRequest="44" />
                        <Label Text="{Binding WeightTrendText}" Style="{StaticResource MutedLabel}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Workouts -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenCommand}" CommandParameter="WorkoutsView" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Last workout" Style="{StaticResource MetricCaption}" />
                        <Label Text="{Binding WorkoutText}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource AccentGreen}" />
                        <Label Text="{Binding WorkoutSubText}" Style="{StaticResource MutedLabel}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Vitamins -->
                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource Card}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenCommand}" CommandParameter="VitaminsView" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Vitamins" Style="{StaticResource MetricCaption}" />
                        <Label Text="{Binding VitaminsText}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource AccentAmber}" />
                        <charts:BarChartView Entries="{Binding VitaminLevels}" BarColor="{StaticResource AccentAmber}" Compact="True" HeightRequest="44" />
                    </VerticalStackLayout>
                </Border>

                <!-- Permissions -->
                <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource Card}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenCommand}" CommandParameter="PermissionsView" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Permissions" Style="{StaticResource MetricCaption}" />
                        <Label Text="{Binding PermissionsText}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource AccentCyan}" />
                        <Label Text="Batched request &amp; check" Style="{StaticResource MutedLabel}" />
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource AccentBlue}" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
