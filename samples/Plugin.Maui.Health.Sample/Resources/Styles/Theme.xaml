<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Card container -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
        <Setter Property="Stroke" Value="{StaticResource Hairline}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="18" />
        </Setter>
        <Setter Property="Shadow">
            <Shadow Brush="#000000" Opacity="0.07" Radius="14" Offset="0,6" />
        </Setter>
    </Style>

    <!-- Typography -->
    <Style x:Key="ScreenTitle" TargetType="Label">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="SectionHeader" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="MetricValue" TargetType="Label">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="MetricCaption" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style x:Key="MutedLabel" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <!-- Buttons -->
    <Style x:Key="AccentButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentBlue}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HeightRequest" Value="44" />
        <Setter Property="Padding" Value="18,0" />
    </Style>

    <Style x:Key="SoftButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Secondary}" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HeightRequest" Value="44" />
        <Setter Property="Padding" Value="18,0" />
    </Style>

    <!-- Inputs -->
    <Style x:Key="SoftEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{StaticResource PageBackground}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="HeightRequest" Value="44" />
    </Style>

</ResourceDictionary>
