<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Plugin.Maui.Health.Sample.ViewModels"
             xmlns:charts="clr-namespace:Plugin.Maui.Health.Sample.Controls"
             x:Class="Plugin.Maui.Health.Sample.Views.BodyMeasurementsView"
             x:DataType="vm:BodyMeasurementsViewViewModel"
             BackgroundColor="{StaticResource PageBackground}"
             Title="Body Measurements">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <ActivityIndicator IsRunning="{Binding IsBusy}" Color="{StaticResource AccentBlue}" HorizontalOptions="Center" />

            <!-- Summary: BMI ring + key stats -->
            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="18">
                    <charts:RingChartView Grid.Column="0"
                                          WidthRequest="120" HeightRequest="120"
                                          Progress="{Binding BmiProgress}"
                                          ValueText="{Binding BmiValueText}"
                                          Caption="BMI"
                                          RingColor="{StaticResource AccentViolet}" />
                    <VerticalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                        <Label Text="Body composition" Style="{StaticResource SectionHeader}" />
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Height" Style="{StaticResource MetricCaption}" />
                            <Label Text="{Binding Height, StringFormat='{0:F0} cm'}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Body mass" Style="{StaticResource MetricCaption}" />
                            <Label Text="{Binding BodyMass, StringFormat='{0:F1} kg'}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Weight trend (line chart) -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Weight trend" Style="{StaticResource SectionHeader}" />
                            <Label Text="{Binding BodyMass, StringFormat='{0:F1} kg'}" Style="{StaticResource MetricValue}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="Read" Style="{StaticResource AccentButton}"
                                Command="{Binding ReadAllBodyMassSamplesCommand}" VerticalOptions="Center" />
                    </Grid>
                    <charts:LineChartView Entries="{Binding WeightTrend}" LineColor="{StaticResource AccentBlue}" />
                </VerticalStackLayout>
            </Border>

            <!-- Height -->
            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2">
                    <Label Grid.Row="0" Text="Height" Style="{StaticResource MetricCaption}" />
                    <Label Grid.Row="1" Text="{Binding Height, StringFormat='{0:F0} cm'}" Style="{StaticResource MetricValue}" />
                    <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Text="Read" Style="{StaticResource SoftButton}"
                            Command="{Binding ReadHeightCommand}" VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Body Mass (read + write) -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2">
                        <Label Grid.Row="0" Text="Body Mass" Style="{StaticResource MetricCaption}" />
                        <Label Grid.Row="1" Text="{Binding BodyMass, StringFormat='{0:F1} kg'}" Style="{StaticResource MetricValue}" />
                        <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Text="Read" Style="{StaticResource SoftButton}"
                                Command="{Binding ReadBodyMassCommand}" VerticalOptions="Center" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Entry Grid.Column="0" Text="{Binding NewBodyMass}" Placeholder="Enter kg" Keyboard="Numeric" Style="{StaticResource SoftEntry}" />
                        <Button Grid.Column="1" Text="Write" Style="{StaticResource AccentButton}" Command="{Binding WriteBodyMassCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Body Mass Index -->
            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2">
                    <Label Grid.Row="0" Text="Body Mass Index" Style="{StaticResource MetricCaption}" />
                    <Label Grid.Row="1" Text="{Binding BodyMassIndex, StringFormat='{0:F1}'}" Style="{StaticResource MetricValue}" />
                    <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Text="Read" Style="{StaticResource SoftButton}"
                            Command="{Binding ReadBodyMassIndexCommand}" VerticalOptions="Center" />
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
