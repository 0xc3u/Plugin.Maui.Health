<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Plugin.Maui.Health.Sample.ViewModels"
             xmlns:charts="clr-namespace:Plugin.Maui.Health.Sample.Controls"
             x:Class="Plugin.Maui.Health.Sample.Views.VitaminsView"
             x:DataType="vm:VitaminsViewViewModel"
             BackgroundColor="{StaticResource PageBackground}"
             Title="Vitamins">
    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="16">

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource AccentBlue}" HorizontalOptions="Center" />

            <!-- Overview: % of reference daily intake -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Daily intake" Style="{StaticResource SectionHeader}" />
                    <Label Text="% of reference daily intake" Style="{StaticResource MutedLabel}" />
                    <charts:BarChartView Entries="{Binding VitaminLevels}" BarColor="{StaticResource AccentAmber}" />
                </VerticalStackLayout>
            </Border>

            <!-- Vitamin C (read + write) -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2">
                        <Label Grid.Row="0" Text="Vitamin C" Style="{StaticResource MetricCaption}" />
                        <Label Grid.Row="1" Text="{Binding VitaminC, StringFormat='{0:F1} mg'}" Style="{StaticResource MetricValue}" />
                        <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Text="Read" Style="{StaticResource SoftButton}"
                                Command="{Binding ReadVitaminCCommand}" VerticalOptions="Center" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Entry Grid.Column="0" Text="{Binding NewVitaminC}" Placeholder="Enter mg" Keyboard="Numeric" Style="{StaticResource SoftEntry}" />
                        <Button Grid.Column="1" Text="Write" Style="{StaticResource AccentButton}" Command="{Binding WriteVitaminCCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Vitamin D -->
            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2">
                    <Label Grid.Row="0" Text="Vitamin D" Style="{StaticResource MetricCaption}" />
                    <Label Grid.Row="1" Text="{Binding VitaminD, StringFormat='{0:F3} mg'}" Style="{StaticResource MetricValue}" />
                    <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Text="Read" Style="{StaticResource SoftButton}"
                            Command="{Binding ReadVitaminDCommand}" VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Vitamin E -->
            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2">
                    <Label Grid.Row="0" Text="Vitamin E" Style="{StaticResource MetricCaption}" />
                    <Label Grid.Row="1" Text="{Binding VitaminE, StringFormat='{0:F1} mg'}" Style="{StaticResource MetricValue}" />
                    <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Text="Read" Style="{StaticResource SoftButton}"
                            Command="{Binding ReadVitaminECommand}" VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Vitamin B6 -->
            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2">
                    <Label Grid.Row="0" Text="Vitamin B6" Style="{StaticResource MetricCaption}" />
                    <Label Grid.Row="1" Text="{Binding VitaminB6, StringFormat='{0:F2} mg'}" Style="{StaticResource MetricValue}" />
                    <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Text="Read" Style="{StaticResource SoftButton}"
                            Command="{Binding ReadVitaminB6Command}" VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Vitamin B12 -->
            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2">
                    <Label Grid.Row="0" Text="Vitamin B12" Style="{StaticResource MetricCaption}" />
                    <Label Grid.Row="1" Text="{Binding VitaminB12, StringFormat='{0:F4} mg'}" Style="{StaticResource MetricValue}" />
                    <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Text="Read" Style="{StaticResource SoftButton}"
                            Command="{Binding ReadVitaminB12Command}" VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Vitamin K -->
            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2">
                    <Label Grid.Row="0" Text="Vitamin K" Style="{StaticResource MetricCaption}" />
                    <Label Grid.Row="1" Text="{Binding VitaminK, StringFormat='{0:F2} mg'}" Style="{StaticResource MetricValue}" />
                    <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Text="Read" Style="{StaticResource SoftButton}"
                            Command="{Binding ReadVitaminKCommand}" VerticalOptions="Center" />
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
